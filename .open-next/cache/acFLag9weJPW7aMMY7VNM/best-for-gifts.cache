\"@type\":\"Product\",\"name\":\"Breathing Red Panda Plush\",\"description\":\"Lifelike red panda plush with realistic breathing simulation. A weighted, calming companion designed for stress relief, anxiety support, and quiet comfort. Hand-crafted for exceptional detail.\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"sku\":\"breathing-red-panda-plush\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/red_panda.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"119.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat 1.1\",\"description\":\"Companion robot cat designed for sensory comfort. Touch-responsive sensors trigger purrs, meows, and gentle movements. Studied through 200+ hours of real cat behavior simulation. Heartbeat feature provides a calming, realistic experience.\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"sku\":\"matecat-1-1\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Mate-Cat-1.1.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"149.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat Pro\",\"description\":\"Hyper-realistic robotic cat with voice wake-up, blinking, purring, and tail movement. Provides emotional support, companionship, and anxiety relief. Handcrafted fur for a premium feel.\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"sku\":\"matecat-pro\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Pro-Mate-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"178.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.6\",\"reviewCount\":456,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Percy 1.1 Robotic Companion Dog\",\"description\":\"Handmade realistic robotic dog with weighted body for sensory comfort, touch sensors, and a calming heartbeat simulation. Crafted through 30+ steps for exceptional detail. Charges via USB-C with 8+ hours of battery.\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"sku\":\"percy-1-1-robotic-companion-dog\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Percy-1.1-Robotic-Companion-Dog.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"pric