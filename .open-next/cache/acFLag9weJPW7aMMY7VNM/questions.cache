children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"cursor-pointer list-none flex items-center justify-between gap-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-base font-semibold text-slate-900 sm:text-lg\\\",\\\"children\\\":\\\"Should I be worried about cameras in pet robots?\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"shrink-0 text-trust-700 text-lg transition-transform group-open:rotate-45\\\",\\\"children\\\":\\\"+\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 max-w-3xl space-y-3 text-sm leading-7 text-slate-700 sm:text-base\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Worried may be too strong, but cautious is reasonable. A camera-equipped robot that moves through your home is functionally different from a fixed security camera: it can travel into private spaces, it stays connected to the manufacturer’s servers, and like any connected device it can be compromised by software vulnerabilities. There have been real, documented incidents — including one where security researchers demonstrated they could take over a major robot vacuum brand and access the camera without any indicator light, and another where a different manufacturer accidentally exposed thousands of users’ camera feeds to strangers.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"None of this means camera-equipped pet robots are unsafe to own; it means the privacy and security features the manufacturer offers should be part of your buying decision, not an afterthought.\\\"}]]}]]}],[\\\"$\\\",\\\"details\\\",null,{\\\"className\\\":\\\"group card p-5 sm:p-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"cursor-pointer list-none flex items-center justify-between gap-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-base font-semibold text-slate-900 sm:text-lg\\\",\\\"children\\\":\\\"What should I look for before buying a connected pet robot?\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"shrink-0 text-trust-700 text-lg transition-transform group-open:rotate-45\\\",\\\"children\\\":\\\"+\\\"}]]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"mt-4 max-w-3xl space-y-3 text-sm leading-7 text-slate-700 sm:text-base\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-slate-900\\\",\\\"children\\\":\\\"A clear, readable privacy policy.\\\"}],\\\" \\\",\\\"Look for explicit statements about what data is collected, where it’s stored, how long it’s kept, and whether it’s shared with third parties.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-slate-900\\\",\\\"children\\\":\\\"Local processing vs. cloud upload.\\\"}],\\\" \\\",\\\"Products that process AI on-device leak less data than products that upload everything to a manufacturer’s cloud. Privacy-focused products will say so explicitly.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-slate-900\\\",\\\"children\\\":\\\"A track record.\\\"}],\\\" \\\",\\\"Search “[product name] security breach” or “[brand] privacy” before buying. Past incidents are a useful signal.\\\"]}]]}],\\\"$L20\\\",\\\"$L21\\\"]}],\\\"$L22\\\",\\\"$L23\\\",\\\"$L24\\\"]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"9:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"section-pad\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container-shell\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-3xl\\\",\\\"children\\\":[null,[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl\\\",\\\"children\\\":\\\"Additional Frequently Asked Questions.\\\"}],nul