1,[],\"\"]\n3:I[4581,[],\"\"]\n4:I[9504,[\"756\",\"static/chunks/756-98a13f2d10827e2b.js\",\"478\",\"static/chunks/478-0efb1bba4c5cfee2.js\",\"921\",\"static/chunks/app/kids-and-families/page-e6fb5a3c20605f42.js\"],\"PageShell\"]\ne:I[7123,[],\"default\",1]\n:HL[\"/_next/static/css/4dd59df00fa48bb6.css\",\"style\"]\n5:T928c,{\"@context\":\"https://schema.org/\",\"@graph\":[{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://interactivepetmarketplace.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Kids & Families\",\"item\":\"https://interactivepetmarketplace.com/kids-and-families\"}]},{\"@type\":\"Product\",\"name\":\"Breathing Red Panda Plush\",\"description\":\"Lifelike red panda plush with realistic breathing simulation. A weighted, calming companion designed for stress relief, anxiety support, and quiet comfort. Hand-crafted for exceptional detail.\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"sku\":\"breathing-red-panda-plush\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/red_panda.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"119.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat 1.1\",\"description\":\"Companion robot cat designed for sensory comfort. Touch-responsive sensors trigger purrs, meows, and gentle movements. Studied through 200+ hours of real cat behavior simulation. Heartbeat feature provides a calming, realistic experience.\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"sku\":\"matecat-1-1\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Mate-Cat-1.1.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"149.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat Pro\",\"description\":\"Hyper-realistic robotic cat with voice wake-up, blinking, purring, and tail movement. Provides emotional support, companionship, and anxiety relief. Handcrafted fur for a premium feel.\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"sku\":\"matecat-pro\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Pro-Mate-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"178.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.6\",\"reviewCount\":456,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Percy 1.1 Robotic Companion Dog\",\"description\":\"Handmade realistic robotic dog with weighted body for sensory comfort, touch sensors, and a calming heartbeat simulation. Crafted through 30+ steps for exceptional detail. Charges via USB-C with 8+ hours of battery.\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"sku\":\"percy-1-1-robotic-companion-dog\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Percy-1.1-Robotic-Companion-Dog.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":5,\"bestRating\":\"5\",\"worstRating\":\"1\"}},{\"@type\":\"Product\",\"name\":\"Percy Robot Cat\",\"description\":\"Affordable handmade robotic cat with five touch-sensitive zones, purring, meowing, and a realistic heartbeat. Weighted plush body designed for emotional support and stress relief.\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"sku\":\"percy-robot-cat\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Robot-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 FamilyBot\",\"description\":\"Enabot's entry level robot. AI home monitoring robot designed to keep your home, pets, and loved ones connected and secure. Interactive laser point allows you to entertain your pets while you are away.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"sku\":\"ebo-air-2-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-10\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":72,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 Plus FamilyBot\",\"description\":\"AI home monitoring robot with AI Assistant designed to keep your home, pets, and loved ones connected and secure. Has all of the features of the EBO 2S plus an AI assistant. Also comes in multiple colors.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"sku\":\"ebo-air-2-plus-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2-Plus.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"359.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":42,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2S FamilyBot\",\"description\":\"Newer generation than the EBO Air 2 with more features. AI home monitoring robot designed to keep your home, pets, and loved ones connected and secure. Does not include the AI Assistant. White option only.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2s\",\"sku\":\"ebo-air-2s-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2S.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"279.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2s\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-09\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO X FamilyBot\",\"description\":\"High resolution camera. Home monitoring robot with AI Assistant keeps your home, pets, and loved ones connected and secure. Includes Smart Tracking and Sound Source Location for enhanced monitoring.\",\"url\":\"https://www.enabot.com/home-robot/ebo-x\",\"sku\":\"ebo-x-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-X.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"789.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-x\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-07\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":20,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"ROLA Mini Pet Monitor\",\"description\":\"AI home monitoring robot with 2-way remote communication designed to keep your pets entertained, connected, and secure.\",\"url\":\"https://www.enabot.com/pet-robot/rola-mini\",\"sku\":\"rola-mini-pet-monitor\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Enabot-ROLA-Mini.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"139.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/pet-robot/rola-mini\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-11\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":73,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Orange Tabby\",\"description\":\"Animatronic orange tabby cat with realistic purring, soft fur, and lifelike movements. Meows, grooms, and rolls over to touch. Award-winning companion pet for seniors.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"sku\":\"companion-pet-cat-orange-tabby\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Orange-Tabby.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Silver\",\"description\":\"Animatronic silver-and-white cat that purrs, meows, and rolls over for tummy rubs. Helps reduce loneliness and