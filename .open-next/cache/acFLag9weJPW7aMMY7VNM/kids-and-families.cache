",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat 1.1\",\"description\":\"Companion robot cat designed for sensory comfort. Touch-responsive sensors trigger purrs, meows, and gentle movements. Studied through 200+ hours of real cat behavior simulation. Heartbeat feature provides a calming, realistic experience.\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"sku\":\"matecat-1-1\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Mate-Cat-1.1.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"149.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat Pro\",\"description\":\"Hyper-realistic robotic cat with voice wake-up, blinking, purring, and tail movement. Provides emotional support, companionship, and anxiety relief. Handcrafted fur for a premium feel.\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"sku\":\"matecat-pro\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Pro-Mate-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"178.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.6\",\"reviewCount\":456,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Percy 1.1 Robotic Companion Dog\",\"description\":\"Handmade realistic robotic dog with weighted body for sensory comfort, touch sensors, and a calming heartbeat simulation. Crafted through 30+ steps for exceptional detail. Charges via USB-C with 8+ hours of battery.\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"sku\":\"percy-1-1-robotic-companion-dog\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Percy-1.1-Robotic-Companion-Dog.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":5,\"bestRating\":\"5\",\"worstRating\":\"1\"}},{\"@type\":\"Product\",\"name\":\"Percy Robot Cat\",\"description\":\"Affordable handmade robotic cat with five touch-sensitive zones, purring, meowing, and a realistic heartbeat. Weighted plush body designed for emotional support and stress relief.\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"sku\":\"percy-robot-cat\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Robot-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 FamilyBot\",\"description\":\"Enabot's entry level robot. AI home monitoring robot designed to keep your home, pets, and loved ones connected and secure. Interactive laser point allows you to entertain your pets while you are away.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"sku\":\"ebo-air-2-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-10\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":72,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 Plus FamilyBot\",\"description\":\"AI home monitoring robot with AI Assistant designed to keep your home, pets, and loved ones connected and secure. Has all of the features of the EBO 2S plus an AI assistant. Also comes in multiple colors.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"sku\":\"ebo-air-2-plus-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2-Plus.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"359.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":42,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2S FamilyBot\",\"description\":\"Newer generation than the EBO Air 2 with more features. AI home monitoring robot designed to keep your home, pets, and loved ones connected and secure. Does not include the AI Assistant. White option only.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2s\",\"sku\":\"ebo-air-2s-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2S.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"279.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2s\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-09\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO X FamilyBot\",\"description\":\"High resolution camera. Home monitoring robot with AI Assistant keeps your home, pets, and loved ones connected and secure. Includes Smart Tracking and Sound Source Location for enhanced monitoring.\",\"url\":\"https://www.enabot.com/home-robot/ebo-x\",\"sku\":\"ebo-x-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-X.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"789.00\",\"priceCurrency