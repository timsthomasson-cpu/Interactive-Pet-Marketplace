children\":[[\"$\",\"p\",null,{\"children\":\"Interactive Pet Marketplace may participate in affiliate programs. If you click a \\\"View Details\\\" or product link on this site and go on to buy, we may earn a small commission at no extra cost to you. Any commissions help fund the time it takes to research products, verify prices, and keep the site running. Specific affiliate programs we participate in will be listed here once they are active.\"}],[\"$\",\"p\",null,{\"children\":\"Earning a commission does not change which products appear on this site or where they rank. We list products based on what we think fits a given shopper, not based on which one pays us more. If a product is a poor fit for a category, we don't include it just because the affiliate payout would be higher.\"}],[\"$\",\"p\",null,{\"children\":\"We are not the manufacturer or seller of any product listed. For order questions, returns, or warranty support, please go directly to the retailer where you purchased.\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-slate-600\",\"children\":\"This disclosure is provided in accordance with the U.S. Federal Trade Commission's guidance on endorsements and testimonials.\"}]]}]]}]}]}]\n9:[\"$\",\"section\",null,{\"className\":\"pb-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-shell\",\"children\":[\"$\",\"div\",null,{\"className\":\"card p-6 sm:p-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\",\"children\":\"Who runs this site\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-base leading-8 text-slate-700\",\"children\":[\"$\",\"p\",null,{\"children\":[\"Interactive Pet Marketplace is curated and researched by\",\" \",[\"$\",\"span\",null,{\"className\":\"font-semibold text-slate-900\",\"children\":\"Tim Thomasson\"}],\". Product research, privacy reviews, and editorial decisions are made by a single person — not an anonymous team or an AI content pipeline. Every product on this site has been chosen, reviewed, and written about by hand.\"]}]}]]}]}]}]\na:[\"$\",\"section\",null,{\"className\":\"pb-16 sm:pb-20\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"card p-6 sm:p-10 text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\",\"children\":\"Have any questions or suggestions?\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-base leading-7 text-slate-700\",\"children\":\"Whether you're trying to decide between two products, want to suggest a pet we should review, or noticed something on the site that doesn't look right — we'd like to hear from you.\"}],[\"$\",\"$Lf\",null,{\"href\":\"/contact\",\"className\":\"btn-primary mt-6 inline-flex\",\"children\":\"Contact us\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-xs text-slate-500 sm:text-sm\",\"children\":[\"Last updated: \",[\"$\",\"time\",null,{\"dateTime\":\"2026-05-17\",\"children\":\"2026-05-17\"}]]}]}]]}]}]\nb:[\"$\",\"$L10\",null,{\"children\":[\"$\",\"$11\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@12\"}]}]\n13:[]\nc:\"$W13\"\nd:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L14\",null,{\"children\":\"$L15\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$11\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L17\"}]}]}],null]}]\n15:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n18:I[6869,[],\"IconMark\"]\n12:null\n17:[[\"$\",\"title\",\"0\",{\"children\":\"About | Interactive Pet Marketplace\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Who we are, how we choose products, and our affiliate disclosure.\"}],[\"$\",\"meta\",\"2\",{\"property\":\"og:title\",\"content\":\