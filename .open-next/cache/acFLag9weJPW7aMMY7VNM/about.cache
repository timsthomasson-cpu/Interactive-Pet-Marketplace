{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"},"segmentPaths":["/_tree","/_full","/about/__PAGE__","/about","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/logo-mark.svg\"/><link rel=\"stylesheet\" href=\"/_next/static/css/4dd59df00fa48bb6.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-c8f26765e38997e7.js\"/><script src=\"/_next/static/chunks/4bd1b696-215e5051988c3dde.js\" async=\"\"></script><script src=\"/_next/static/chunks/794-5fb6eff04a716ab6.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-b3c0850c1bc99792.js\" async=\"\"></script><script src=\"/_next/static/chunks/756-98a13f2d10827e2b.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/about/page-1f374704d40e8be0.js\" async=\"\"></script><title>About | Interactive Pet Marketplace</title><meta name=\"description\" content=\"Who we are, how we choose products, and our affiliate disclosure.\"/><meta property=\"og:title\" content=\"Interactive Pet Marketplace — Compare interactive pets and AI &amp; robotic pets\"/><meta property=\"og:description\" content=\"Honest comparisons of interactive pets, plushy companions, and AI &amp; robotic pets for seniors, families, and gift buyers.\"/><meta property=\"og:url\" content=\"https://interactivepetmarketplace.com\"/><meta property=\"og:site_name\" content=\"Interactive Pet Marketplace\"/><meta property=\"og:image\" content=\"https://interactivepetmarketplace.com/og-image.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Interactive Pet Marketplace — Compare interactive pets and AI &amp; robotic pets\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Interactive Pet Marketplace\"/><meta name=\"twitter:description\" content=\"Honest comparisons of interactive pets, plushy companions, and AI &amp; robotic pets for seniors, families, and gift buyers.\"/><meta name=\"twitter:image\" content=\"https://interactivepetmarketplace.com/og-image.png\"/><link rel=\"icon\" href=\"/favicon.ico\" sizes=\"any\"/><link rel=\"icon\" href=\"/favicon-32x32.png\" sizes=\"32x32\" type=\"image/png\"/><link rel=\"icon\" href=\"/logo-mark.svg\" type=\"image/svg+xml\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-40 border-b border-coral-200 bg-white/95 backdrop-blur\"><div class=\"container-shell flex items-center justify-between gap-6 py-4\"><a class=\"flex items-center gap-3\" href=\"/\"><img src=\"/logo-mark.svg\" alt=\"\" width=\"44\" height=\"44\" class=\"h-11 w-11\"/><div><div class=\"text-sm font-semibold text-brand-700\">Interactive Pet Marketplace</div><div class=\"hidden sm:block text-xs text-slate-500\">Interactive &amp; AI companion guides</div></div></a><nav class=\"hidden items-center gap-5 lg:flex\"><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/\">Home</a><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/plushy-companions\">Plushy Companions</a><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/ai-robotic-pets\">AI &amp; Robotic Pets</a><div class=\"relative\"><button aria-expanded=\"false\" aria-haspopup=\"true\" class=\"flex items-center gap-1 text-sm transition hover:text-brand-700 font-medium text-slate-700\">Shop for<svg class=\"h-3 w-3 transition-transform \" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></button></div><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/compare\">Compare</a><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/questions\">Questions?</a><a aria-current=\"page\" class=\"text-sm transition hover:text-brand-700 font-semibold text-trust-700\" href=\"/about\">About</a><a class=\"text-sm transition hover:text-brand-700 font-medium text-slate-700\" href=\"/contact\">Contact</a></nav><a class=\"hidden sm:inline-flex items-center justify-center rounded-full bg-trust-500 px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-trust-600\" href=\"/top-picks\">Shop Top Picks</a></div><nav class=\"lg:hidden border-t border-coral-100 bg-white\"><div class=\"no-scrollbar flex gap-2 overflow-x-auto px-4 py-2.5\"><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/\">Home</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/plushy-companions\">Plushy Companions</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/ai-robotic-pets\">AI &amp; Robotic Pets</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/best-for-seniors\">Seniors</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/kids-and-families\">Kids &amp; Families</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/best-for-gifts\">Gifts</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/premium-picks\">Premium Picks</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/compare\">Compare</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/questions\">Questions?</a><a aria-current=\"page\" class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-trust-500 bg-trust-500 text-white\" href=\"/about\">About</a><a class=\"shrink-0 rounded-full border px-4 py-1.5 text-xs font-semibold transition border-coral-200 bg-cream-50 text-slate-700 hover:border-trust-400 hover:bg-trust-50 hover:text-trust-700\" href=\"/contact\">Contact</a></div></nav></header><main><script type=\"application/ld+json\">{\"@context\":\"https://schema.org/\",\"@graph\":[{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://interactivepetmarketplace.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"About\",\"item\":\"https://interactivepetmarketplace.com/about\"}]},{\"@type\":\"AboutPage\",\"name\":\"About Interactive Pet Marketplace\",\"url\":\"https://interactivepetmarketplace.com/about\",\"author\":{\"@type\":\"Person\",\"name\":\"Tim Thomasson\",\"jobTitle\":\"Curator and researcher\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Interactive Pet Marketplace\",\"url\":\"https://interactivepetmarketplace.com\"}}}]}</script><section class=\"pt-14 pb-6 sm:pt-16 sm:pb-7 lg:pt-20 lg:pb-10\"><div class=\"container-shell\"><div class=\"max-w-3xl\"><p class=\"eyebrow\">About</p><h1 class=\"mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl\">A cleaner way to compare interactive pets.</h1><p class=\"mt-4 text-lg leading-8 text-slate-600\">Interactive Pet Marketplace exists to make it easier to find the right interactive pet, AI &amp; robotic pet, or plushy companion — without wading through cluttered review sites.</p></div></div></section><section class=\"pb-12\"><div class=\"container-shell\"><div class=\"grid gap-8 lg:grid-cols-[1fr_1.2fr]\"><div><p class=\"eyebrow\">What we do</p><h2 class=\"mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\">Honest comparisons, organized by who you&#x27;re shopping for.</h2></div><div class=\"space-y-4 text-base leading-7 text-slate-700\"><p>There are a lot of interactive pets on the market, and they get marketed as the answer to very different needs — companionship for a parent living alone, a calming presence for someone with dementia, a novelty gift, or a kid&#x27;s first taste of a &quot;pet.&quot; Lumping them all together makes choosing harder, not easier.</p><p>The team behind Interactive Pet Marketplace organizes products by who they&#x27;re best for and what they actually do, so you can narrow things down quickly. We focus on plushy companions, AI &amp; robotic pets, and senior-friendly options — the categories where buyers most often tell us they feel overwhelmed.</p></div></div></div></section><section class=\"pb-12\"><div class=\"container-shell\"><div class=\"card p-6 sm:p-10\"><p class=\"eyebrow\">How we choose what to list</p><h2 class=\"mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\">Our standards for product information.</h2><div class=\"mt-6 grid gap-6 md:grid-cols-2\"><div><h3 class=\"text-lg font-semibold text-slate-900\">Verified data only</h3><p class=\"mt-2 text-sm leading-7 text-slate-600\">Specs, ratings, review counts, and prices come from manufacturer pages or major retailers and are checked manually. If we can&#x27;t verify a number, it doesn&#x27;t go on the site.</p></div><div><h3 class=\"text-lg font-semibold text-slate-900\">Refreshed regularly</h3><p class=\"mt-2 text-sm leading-7 text-slate-600\">Prices and ratings drift over time. Higher-priced and popular products get checked more often than long-tail listings, and every product card reflects when the data was last verified.</p></div><div><h3 class=\"text-lg font-semibold text-slate-900\">No copied reviews</h3><p class=\"mt-2 text-sm leading-7 text-slate-600\">We never reproduce customer review text from Amazon, the manufacturer, or anywhere else. Reviews belong to the people who wrote them. We link out instead.</p></div><div><h3 class=\"text-lg font-semibold text-slate-900\">Editorial highlights are ours</h3><p class=\"mt-2 text-sm leading-7 text-slate-600\">Where we add a short &quot;what makes this stand out&quot; note, that&#x27;s our editorial voice — not a manufacturer claim. We try to be clear about which is which.</p></div></div></div></div></section><section class=\"pb-12\"><div class=\"container-shell\"><p class=\"eyebrow\">Who this site is for</p><h2 class=\"mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\">We organize the site around shoppers, not categories.</h2><div class=\"mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-4\"><div class=\"rounded-3xl border border-trust-200 bg-trust-50 p-6\"><h3 class=\"text-lg font-semibold text-trust-900\">Seniors and their families</h3><p class=\"mt-3 text-sm leading-7 text-slate-600\">Calmer choices with simple interaction, designed for comfort over complexity.</p></div><div class=\"rounded-3xl border border-trust-200 bg-trust-50 p-6\"><h3 class=\"text-lg font-semibold text-trust-900\">Kids and families</h3><p class=\"mt-3 text-sm leading-7 text-slate-600\">Playful options built for novelty, learning, and everyday entertainment.</p></div><div class=\"rounded-3xl border border-trust-200 bg-trust-50 p-6\"><h3 class=\"text-lg font-semibold text-trust-900\">Gift buyers</h3><p class=\"mt-3 text-sm leading-7 text-slate-600\">Friendly picks with broad appeal that don&#x27;t require setup expertise.</p></div><div class=\"rounded-3xl border border-trust-200 bg-trust-50 p-6\"><h3 class=\"text-lg font-semibold text-trust-900\">Premium shoppers</h3><p class=\"mt-3 text-sm leading-7 text-slate-600\">Higher-end robotic pets with more advanced sensors and movement.</p></div></div></div></section><section class=\"pb-12\"><div class=\"container-shell\"><div id=\"affiliate-disclosure\" class=\"rounded-3xl border-2 border-trust-300 bg-trust-50 p-6 sm:p-10\"><p class=\"eyebrow\">Affiliate disclosure</p><h2 class=\"mt-3 text-2xl font-bold tracking-tight text-trust-900 sm:text-3xl\">How we make money — in plain language.</h2><div class=\"mt-5 space-y-4 text-base leading-7 text-slate-700\"><p>Interactive Pet Marketplace may participate in affiliate programs. If you click a &quot;View Details&quot; or product link on this site and go on to buy, we may earn a small commission at no extra cost to you. Any commissions help fund the time it takes to research products, verify prices, and keep the site running. Specific affiliate programs we participate in will be listed here once they are active.</p><p>Earning a commission does not change which products appear on this site or where they rank. We list products based on what we think fits a given shopper, not based on which one pays us more. If a product is a poor fit for a category, we don&#x27;t include it just because the affiliate payout would be higher.</p><p>We are not the manufacturer or seller of any product listed. For order questions, returns, or warranty support, please go directly to the retailer where you purchased.</p><p class=\"text-sm text-slate-600\">This disclosure is provided in accordance with the U.S. Federal Trade Commission&#x27;s guidance on endorsements and testimonials.</p></div></div></div></section><section class=\"pb-12\"><div class=\"container-shell\"><div class=\"card p-6 sm:p-10\"><h2 class=\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\">Who runs this site</h2><div class=\"mt-4 space-y-4 text-base leading-8 text-slate-700\"><p>Interactive Pet Marketplace is curated and researched by<!-- --> <span class=\"font-semibold text-slate-900\">Tim Thomasson</span>. Product research, privacy reviews, and editorial decisions are made by a single person — not an anonymous team or an AI content pipeline. Every product on this site has been chosen, reviewed, and written about by hand.</p></div></div></div></section><section class=\"pb-16 sm:pb-20\"><div class=\"container-shell\"><div class=\"card p-6 sm:p-10 text-center\"><h2 class=\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\">Have any questions or suggestions?</h2><p class=\"mt-3 text-base leading-7 text-slate-700\">Whether you&#x27;re trying to decide between two products, want to suggest a pet we should review, or noticed something on the site that doesn&#x27;t look right — we&#x27;d like to hear from you.</p><a class=\"btn-primary mt-6 inline-flex\" href=\"/contact\">Contact us</a></div><div class=\"mt-8 text-center\"><p class=\"text-xs text-slate-500 sm:text-sm\">Last updated: <time dateTime=\"2026-05-17\">2026-05-17</time></p></div></div></section></main><footer class=\"border-t border-coral-200 bg-cream-100\"><div class=\"container-shell py-12\"><div class=\"grid gap-10 md:grid-cols-4\"><div class=\"md:col-span-2\"><p class=\"text-base font-semibold text-brand-900\">Interactive Pet Marketplace</p><p class=\"mt-3 max-w-sm text-sm leading-7 text-slate-600\">A cleaner way to compare companion-style plushy companions and AI &amp; robotic pets for seniors, families, and gift buyers.</p></div><div><p class=\"text-sm font-semibold text-brand-900\">Explore</p><div class=\"mt-4 space-y-3 text-sm text-slate-600\"><a class=\"block hover:text-brand-700\" href=\"/plushy-companions\">Plushy Companions</a><a class=\"block hover:text-brand-700\" href=\"/ai-robotic-pets\">AI &amp; Robotic Pets</a><a class=\"block hover:text-brand-700\" href=\"/best-for-seniors\">Seniors</a><a class=\"block hover:text-brand-700\" href=\"/compare\">Compare</a></div></div><div><p class=\"text-sm font-semibold text-brand-900\">About this site</p><div class=\"mt-4 space-y-3 text-sm text-slate-600\"><a class=\"block hover:text-brand-700\" href=\"/about\">About</a><a class=\"block hover:text-brand-700\" href=\"/contact\">Contact</a><a class=\"block hover:text-brand-700\" href=\"/about#affiliate-disclosure\">Affiliate disclosure</a></div></div></div><div class=\"mt-10 border-t border-coral-200 pt-6\"><p class=\"text-xs leading-6 text-slate-500\">Interactive Pet Marketplace may participate in affiliate programs and may earn a commission when you buy through links on this site, at no extra cost to you. See our <a class=\"underline hover:text-brand-700\" href=\"/about#affiliate-disclosure\">full affiliate disclosure</a> for details.</p></div></div></footer><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-c8f26765e38997e7.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7121,[],\\\"\\\"]\\n3:I[4581,[],\\\"\\\"]\\n4:I[9504,[\\\"756\\\",\\\"static/chunks/756-98a13f2d10827e2b.js\\\",\\\"220\\\",\\\"static/chunks/app/about/page-1f374704d40e8be0.js\\\"],\\\"PageShell\\\"]\\ne:I[7123,[],\\\"default\\\",1]\\n:HL[\\\"/_next/static/css/4dd59df00fa48bb6.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0: