",\"children\":[\"$\",\"div\",null,{\"id\":\"affiliate-disclosure\",\"className\":\"rounded-3xl border-2 border-trust-300 bg-trust-50 p-6 sm:p-10\",\"children\":[[\"$\",\"p\",null,{\"className\":\"eyebrow\",\"children\":\"Affiliate disclosure\"}],[\"$\",\"h2\",null,{\"className\":\"mt-3 text-2xl font-bold tracking-tight text-trust-900 sm:text-3xl\",\"children\":\"How we make money — in plain language.\"}],[\"$\",\"div\",null,{\"className\":\"mt-5 space-y-4 text-base leading-7 text-slate-700\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Interactive Pet Marketplace may participate in affiliate programs. If you click a \\\"View Details\\\" or product link on this site and go on to buy, we may earn a small commission at no extra cost to you. Any commissions help fund the time it takes to research products, verify prices, and keep the site running. Specific affiliate programs we participate in will be listed here once they are active.\"}],[\"$\",\"p\",null,{\"children\":\"Earning a commission does not change which products appear on this site or where they rank. We list products based on what we think fits a given shopper, not based on which one pays us more. If a product is a poor fit for a category, we don't include it just because the affiliate payout would be higher.\"}],[\"$\",\"p\",null,{\"children\":\"We are not the manufacturer or seller of any product listed. For order questions, returns, or warranty support, please go directly to the retailer where you purchased.\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-slate-600\",\"children\":\"This disclosure is provided in accordance with the U.S. Federal Trade Commission's guidance on endorsements and testimonials.\"}]]}]]}]}]}]\n7:[\"$\",\"section\",null,{\"className\":\"pb-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-shell\",\"children\":[\"$\",\"div\",null,{\"className\":\"card p-6 sm:p-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\",\"children\":\"Who runs this site\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-base leading-8 text-slate-700\",\"children\":[\"$\",\"p\",null,{\"children\":[\"Interactive Pet Marketplace is curated and researched by\",\" \",[\"$\",\"span\",null,{\"className\":\"font-semibold text-slate-900\",\"children\":\"Tim Thomasson\"}],\". Product research, privacy reviews, and editorial decisions are made by a single person — not an anonymous team or an AI content pipeline. Every product on this site has been chosen, reviewed, and written about by hand.\"]}]}]]}]}]}]\n8:[\"$\",\"section\",null,{\"className\":\"pb-16 sm:pb-20\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"card p-6 sm:p-10 text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl\",\"children\":\"Have any questions or suggestions?\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-base leading-7 text-slate-700\",\"children\":\"Whether you're trying to decide between two products, want to suggest a pet we should review, or noticed something on the site that doesn't look right — we'd like to hear from you.\"}],[\"$\",\"$La\",null,{\"href\":\"/contact\",\"className\":\"btn-primary mt-6 inline-flex\",\"children\":\"Contact us\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-xs text-slate-500 sm:text-sm\",\"children\":[\"Last updated: \",[\"$\",\"time\",null,{\"dateTime\":\"2026-05-17\",\"children\":\"2026-05-17\"}]]}]}]]}]}]\n9:[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"$c\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@d\"}]}]\nd:null\n","/about":"1:\"$Sreact.fragment\"\n2:I[7121,[],\"\"]\n3:I[4581,[],\"\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"isParti