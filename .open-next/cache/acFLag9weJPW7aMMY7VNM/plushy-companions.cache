/chongker.com/products/percy-interactive-cat\",\"sku\":\"percy-robot-cat\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Robot-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Orange Tabby\",\"description\":\"Animatronic orange tabby cat with realistic purring, soft fur, and lifelike movements. Meows, grooms, and rolls over to touch. Award-winning companion pet for seniors.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"sku\":\"companion-pet-cat-orange-tabby\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Orange-Tabby.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Silver\",\"description\":\"Animatronic silver-and-white cat that purrs, meows, and rolls over for tummy rubs. Helps reduce loneliness and dementia-related agitation with soothing VibraPurr technology.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273487915\",\"sku\":\"companion-pet-cat-silver\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Silver.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273487915\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Tuxedo\",\"description\":\"Animatronic black-and-white tuxedo cat with realistic purring, motion-responsive interactions, and soft hypoallergenic fur. A calming, low-maintenance companion for any age.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"sku\":\"companion-pet-cat-tuxedo\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Tuxedo.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Pup Freckled\",\"description\":\"Lifelike animatronic puppy with brown-and-white freckled fur, floppy ears, BarkBack voice response, and calming heartbeat. The newest Joy for All companion pet for seniors.\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"sku\":\"companion-pet-pup-freckled\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-For-All-Freckled-Pup.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.3\",\"reviewCount\":5163,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Pup Golden\",\"description\":\"Lifelike animatronic Golden Retriever puppy with BarkBack voice response, calming heartbeat, and soft hypoallergenic fur. Created with caregivers to comfort seniors with Alzheimer’s and dementia\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"sku\":\"companion-pet-pup-golden\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-For-All-Golden-Pup.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.3\",\"reviewCount\":5164,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Produ