\"@type\":\"Product\",\"name\":\"Breathing Red Panda Plush\",\"description\":\"Lifelike red panda plush with realistic breathing simulation. A weighted, calming companion designed for stress relief, anxiety support, and quiet comfort. Hand-crafted for exceptional detail.\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"sku\":\"breathing-red-panda-plush\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/red_panda.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"119.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/breathing-red-panda\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat 1.1\",\"description\":\"Companion robot cat designed for sensory comfort. Touch-responsive sensors trigger purrs, meows, and gentle movements. Studied through 200+ hours of real cat behavior simulation. Heartbeat feature provides a calming, realistic experience.\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"sku\":\"matecat-1-1\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Mate-Cat-1.1.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"149.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat10-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.0\",\"reviewCount\":2,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"MateCat Pro\",\"description\":\"Hyper-realistic robotic cat with voice wake-up, blinking, purring, and tail movement. Provides emotional support, companionship, and anxiety relief. Handcrafted fur for a premium feel.\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"sku\":\"matecat-pro\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Pro-Mate-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"178.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/matecat-pro-hyper-realistic-bionic-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.6\",\"reviewCount\":456,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Percy 1.1 Robotic Companion Dog\",\"description\":\"Handmade realistic robotic dog with weighted body for sensory comfort, touch sensors, and a calming heartbeat simulation. Crafted through 30+ steps for exceptional detail. Charges via USB-C with 8+ hours of battery.\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"sku\":\"percy-1-1-robotic-companion-dog\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Percy-1.1-Robotic-Companion-Dog.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":5,\"bestRating\":\"5\",\"worstRating\":\"1\"}},{\"@type\":\"Product\",\"name\":\"Percy Robot Cat\",\"description\":\"Affordable handmade robotic cat with five touch-sensitive zones, purring, meowing, and a realistic heartbeat. Weighted plush body designed for emotional support and stress relief.\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"sku\":\"percy-robot-cat\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Chongker-Percy-Robot-Cat.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-interactive-cat\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":16,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Chongker website\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Orange Tabby\",\"description\":\"Animatronic orange tabby cat with realistic purring, soft fur, and lifelike movements. Meows, grooms, and rolls over to touch. Award-winning companion pet for seniors.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"sku\":\"companion-pet-cat-orange-tabby\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Orange-Tabby.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273455147\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Silver\",\"description\":\"Animatronic silver-and-white cat that purrs, meows, and rolls over for tummy rubs. Helps reduce loneliness and dementia-related agitation with soothing VibraPurr technology.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273487915\",\"sku\":\"companion-pet-cat-silver\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Silver.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=10404273487915\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Tuxedo\",\"description\":\"Animatronic black-and-white tuxedo cat with realistic purring, motion-responsive interactions, and soft hypoallergenic fur. A calming, low-maintenance companion for any age.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"sku\":\"companion-pet-cat-tuxedo\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Tuxedo.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=129