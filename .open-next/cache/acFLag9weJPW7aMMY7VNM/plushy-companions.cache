anization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Tuxedo\",\"description\":\"Animatronic black-and-white tuxedo cat with realistic purring, motion-responsive interactions, and soft hypoallergenic fur. A calming, low-maintenance companion for any age.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"sku\":\"companion-pet-cat-tuxedo\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Tuxedo.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Pup Freckled\",\"description\":\"Lifelike animatronic puppy with brown-and-white freckled fur, floppy ears, BarkBack voice response, and calming heartbeat. The newest Joy for All companion pet for seniors.\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"sku\":\"companion-pet-pup-freckled\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-For-All-Freckled-Pup.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyf