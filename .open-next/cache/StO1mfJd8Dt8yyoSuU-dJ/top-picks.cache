riceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.6\",\"reviewCount\":456,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Percy 1.1 Robotic Companion Dog\",\"description\":\"Handmade realistic robotic dog with weighted body for sensory comfort, touch sensors, and a calming heartbeat simulation. Crafted through 30+ steps for exceptional detail. Charges via USB-C with 8+ hours of battery.\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"sku\":\"percy-1-1-robotic-companion-dog\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Chongker\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Percy-1.1-Robotic-Companion-Dog.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"89.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://chongker.com/products/percy-robotic-dog-companion-designed-for-comfort\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Chongker Website\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":5,\"bestRating\":\"5\",\"worstRating\":\"1\"}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 FamilyBot\",\"description\":\"Enabot's entry level robot. AI home monitoring robot designed to keep your home, pets, and loved ones connected and secure. Interactive laser point allows you to entertain your pets while you are away.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"sku\":\"ebo-air-2-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-10\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":72,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"EBO Air 2 Plus FamilyBot\",\"description\":\"AI home monitoring robot with AI Assistant designed to keep your home, pets, and loved ones connected and secure. Has all of the features of the EBO 2S plus an AI assistant. Also comes in multiple colors.\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"sku\":\"ebo-air-2-plus-familybot\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Enabot\"},\"image\":\"https://interactivepetmarketplace.com/images/products/EBO-Air-2-Plus.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"359.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://www.enabot.com/home-robot/ebo-air-2-plus\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":42,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Enabot Store\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Cat Tuxedo\",\"description\":\"Animatronic black-and-white tuxedo cat with realistic purring, motion-responsive interactions, and soft hypoallergenic fur. A calming, low-maintenance companion for any age.\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"sku\":\"companion-pet-cat-tuxedo\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-for-All-Companion-Cat-Tuxedo.jpg\",\"offers\":{\"@type\":\"Offer\",\"price\":\"159.99\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-cats?variant=12931092676651\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.5\",\"reviewCount\":11640,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"Companion Pet Pup Golden\",\"description\":\"Lifelike animatronic Golden Retriever puppy with BarkBack voice response, calming heartbeat, and soft hypoallergenic fur. Created with caregivers to comfort seniors with Alzheimer’s and dementia\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"sku\":\"companion-pet-pup-golden\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Joy for All\"},\"image\":\"https://interactivepetmarketplace.com/images/products/Joy-For-All-Golden-Pup.png\",\"offers\":{\"@type\":\"Offer\",\"price\":\"179.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://joyforall.com/products/companion-pet-pup?variant=37624426102967\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Amazon\"},\"priceValidUntil\":\"2026-05-08\"},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.3\",\"reviewCount\":5164,\"bestRating\":\"5\",\"worstRating\":\"1\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Amazon\"}}},{\"@type\":\"Product\",\"name\":\"DJ Furby\",\"description\":\"DJ Furby Interactive Plush is an interactive electronic pet with voice activation, music, lights, and touch response. Furby encourages imaginative play, conversation, and screen-free entertainment for kids and nostalgic collectors alike.\",\"url\":\"https://www.amazon.com/s?k=furby+dj&crid=1U6BER2BCWJV5&sprefix=furby+%2Caps%2C205&ref=nb_sb_ss_p13n-expert-pd-ops-ranker_7_6\",\"sku\":\"dj-furby\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Furby\"},\"image\":\"https://interactivepetmarketplace.com/images/products/DJ-Furby.p