# Google Analytics 4 Measurement ID
# Get this from analytics.google.com -> Admin -> Data Streams -> your web stream
# Format: G-XXXXXXXXXX
#
# Copy this file to .env.local (same folder as package.json) and replace the
# placeholder with your real Measurement ID. Do NOT commit .env.local.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
